########################################
# Vivado generated files (always ignore)
########################################
*.cache/
*.hw/
*.runs/
*.sim/
*.gen/
*.ip_user_files/
.Xil/

########################################
# Logs / temp
########################################
*.log
*.jou
*.str
*.backup.*
*.wdb

########################################
# OS / editor junk
########################################
.DS_Store
Thumbs.db

########################################
# Ignore ALL IP-generated contents
########################################
FDP/FDP.srcs/sources_1/ip/*

# Re-include ONLY the IP definition files
!FDP/FDP.srcs/sources_1/ip/*/
FDP/FDP.srcs/sources_1/ip/**/*.*
!FDP/FDP.srcs/sources_1/ip/**/*.xci
!FDP/FDP.srcs/sources_1/ip/**/*.coe
!FDP/FDP.srcs/sources_1/ip/**/*.mif

########################################
# Ignore useless Vivado summary files
########################################
*archive_project_summary.txt
